<?xml version="1.0" ?>
<robot name="pal_sea_arm" xmlns:xacro="http://ros.org/wiki/xacro">

    <xacro:include filename="$(find pal_sea_arm_moveit_config)/config/srdf/disable_collisions/pal_sea_arm_no-ee.srdf.xacro" />

    <disable_collisions link1="wrist_ft_sensor_base_link" link2="wrist_ft_sensor_link" reason="Adjacent"/>
    <disable_collisions link1="wrist_ft_sensor_base_link" link2="wrist_ft_tool_link" reason="Adjacent"/>
    <disable_collisions link1="wrist_ft_sensor_link" link2="wrist_ft_tool_link" reason="Never"/>

</robot>